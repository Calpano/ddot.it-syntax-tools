{
  "scopeName": "source.ddot",
  "name": "ddot.it",
  "patterns": [
    { "include": "#disabled" },
    { "include": "#metadata" },
    { "include": "#triples" },
    { "include": "#additional" },
    { "include": "#commands" }
  ],
  "repository": {
    "disabled": {
      "patterns": [
        {
          "name": "comment.block.disabled.ddot",
          "begin": "(?:\\bddot\\.it/off\\b|!!off\\b)",
          "end": "(?:\\bddot\\.it/on\\b|!!on\\b)",
          "beginCaptures": {
            "0": { "name": "keyword.control.ddot" }
          },
          "endCaptures": {
            "0": { "name": "keyword.control.ddot" }
          }
        }
      ]
    },
    "commands": {
      "patterns": [
        {
          "name": "keyword.control.ddot",
          "match": "\\bddot\\.it(?:/[A-Za-z][A-Za-z0-9_-]*)?\\b|!!(?:[A-Za-z][A-Za-z0-9_-]*)?"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "comment.metadata.ddot",
          "begin": ",,\\s*$",
          "end": "^\\s*,,",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.ddot" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.ddot" }
          },
          "patterns": [
            { "include": "#metadata_triples" },
            { "include": "#commands" }
          ]
        },
        {
          "name": "comment.metadata.ddot",
          "begin": ",,",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.ddot" }
          },
          "patterns": [
            { "include": "#metadata_triples" },
            { "include": "#commands" }
          ]
        }
      ]
    },
    "metadata_triples": {
      "patterns": [
        {
          "match": "\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "name": "comment.metadata.subject.ddot" },
            "2": { "name": "comment.metadata.operator.ddot" },
            "3": { "name": "comment.metadata.relation.ddot" },
            "4": { "name": "comment.metadata.operator.ddot" },
            "5": { "name": "comment.metadata.object.ddot" }
          }
        },
        {
          "match": "\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "name": "comment.metadata.operator.ddot" },
            "2": { "name": "comment.metadata.relation.ddot" },
            "3": { "name": "comment.metadata.operator.ddot" },
            "4": { "name": "comment.metadata.object.ddot" }
          }
        },
        {
          "match": "\\s*(\\.\\.\\.\\.|\\.\\.\\s*\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "name": "comment.metadata.operator.ddot" },
            "2": { "name": "comment.metadata.object.ddot" }
          }
        },
        {
          "name": "comment.metadata.operator.ddot",
          "match": "\\.\\.\\.\\.|\\.\\."
        }
      ]
    },
    "triples": {
      "patterns": [
        {
          "name": "meta.triple.untyped.ddot",
          "match": "^\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.\\.\\.|\\.\\.\\s*\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.subject.ddot" } ] },
            "2": { "name": "entity.name.operator.ddot" },
            "3": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.object.ddot" } ] }
          }
        },
        {
          "name": "meta.triple.typed.ddot",
          "match": "^\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.subject.ddot" } ] },
            "2": { "name": "entity.name.operator.ddot" },
            "3": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.relation.ddot" } ] },
            "4": { "name": "entity.name.operator.ddot" },
            "5": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.object.ddot" } ] }
          }
        }
      ]
    },
    "additional": {
      "patterns": [
        {
          "name": "meta.triple.additional.untyped.ddot",
          "match": "^\\s*(\\.\\.\\.\\.|\\.\\.\\s*\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "name": "entity.name.operator.ddot" },
            "2": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.object.ddot" } ] }
          }
        },
        {
          "name": "meta.triple.additional.typed.ddot",
          "match": "^\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)\\s*(\\.\\.)\\s*((?:(?!\\.\\.|,,).)+?)(?=\\s*(?:,,|$))",
          "captures": {
            "1": { "name": "entity.name.operator.ddot" },
            "2": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.relation.ddot" } ] },
            "3": { "name": "entity.name.operator.ddot" },
            "4": { "patterns": [ { "include": "#commands" }, { "match": ".+", "name": "entity.name.object.ddot" } ] }
          }
        }
      ]
    }
  }
}